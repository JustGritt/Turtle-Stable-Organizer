<footer class="p-4 m-4 bg-white rounded-lg shadow md:flex md:items-center md:justify-between md:p-6 xl:p-8 dark:bg-gray-800">
	<ul class="flex w-full justify-between flex-wrap items-center mb-6 space-y-1 md:mb-0">
		<li>
			<a href="https://github.com/JustGritt/TurtleStableOrganizer"
				class="flex mr-4 text-sm font-normal text-gray-500 hover:underline md:mr-6 dark:text-gray-400">
				<Github />
			</a>
		</li>
			<p class="text-sm text-center text-gray-500 justify-right ">
				&copy; 2023 - {new Date().getFullYear()} — JustGritt
			</p>
		</li>
	</ul>
</footer>